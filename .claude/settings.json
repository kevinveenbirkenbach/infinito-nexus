{
  "env": {
    "GIT_CONFIG_COUNT": "1",
    "GIT_CONFIG_KEY_0": "commit.gpgsign",
    "GIT_CONFIG_VALUE_0": "false"
  },
  "permissions": {
    "allow": [
      "Bash(XDG_CACHE_HOME=/tmp/* gh run view *)",
      "Bash(gh run list *)",
      "Bash(grep *)",
      "Bash(make *)",
      "Bash(tee /tmp/*)",
      "Bash(wc *)",
      "Edit",
      "Read",
      "WebFetch(domain:*)",
      "WebSearch",
      "Write"
    ],
    "deny": [
      "Bash(gh api * --method DELETE *)",
      "Bash(gh api * --method PUT *)",
      "Bash(gh api * -X DELETE *)",
      "Bash(gh api * -X PUT *)",
      "Bash(gh api * /actions/secrets*:*)",
      "Bash(gh api repos/*/actions/variables*:*)",
      "Bash(gh api repos/*/collaborators*:*)",
      "Bash(gh api repos/*/keys*:*)",
      "Bash(gh api repos/*/pulls/*/merge:*)",
      "Bash(gh extension *)",
      "Bash(gh gpg-key *)",
      "Bash(gh issue transfer*)",
      "Bash(gh pr merge*)",
      "Bash(gh repo delete*)",
      "Bash(gh secret *)",
      "Bash(gh ssh-key *)",
      "Bash(gh variable *)",
      "Bash(gh workflow disable*)",
      "Bash(gh workflow enable*)",
      "Bash(git branch -D*)",
      "Bash(git clean*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(sudo*)"
    ],
    "ask": [
      "Bash(docker run*)",
      "Bash(gh * archive*)",
      "Bash(gh * cancel*)",
      "Bash(gh * close*)",
      "Bash(gh * comment*)",
      "Bash(gh * create*)",
      "Bash(gh * delete*)",
      "Bash(gh * develop*)",
      "Bash(gh * edit*)",
      "Bash(gh * field-*)",
      "Bash(gh * fork*)",
      "Bash(gh * item-*)",
      "Bash(gh * link*)",
      "Bash(gh * lock*)",
      "Bash(gh * mark-template*)",
      "Bash(gh * pin*)",
      "Bash(gh * ready*)",
      "Bash(gh * rename*)",
      "Bash(gh * reopen*)",
      "Bash(gh * rerun*)",
      "Bash(gh * review*)",
      "Bash(gh * unlink*)",
      "Bash(gh * unlock*)",
      "Bash(gh * unmark-template*)",
      "Bash(gh * unpin*)",
      "Bash(gh * upload*)",
      "Bash(gh api * --method *)",
      "Bash(gh api * -X *)",
      "Bash(gh api enterprises/*:*)",
      "Bash(gh api orgs/*:*)",
      "Bash(gh api repos/*/actions/permissions*:*)",
      "Bash(gh api repos/*/actions/workflows/*/dispatches:*)",
      "Bash(gh api repos/*/branches/*/protection*:*)",
      "Bash(gh api repos/*/environments*:*)",
      "Bash(gh api repos/*/hooks*:*)",
      "Bash(gh api repos/*/releases*:*)",
      "Bash(gh api repos/*/rulesets*:*)",
      "Bash(gh api teams/*:*)",
      "Bash(gh auth *)",
      "Bash(gh codespace *)",
      "Bash(gh config set*)",
      "Bash(gh label clone*)",
      "Bash(gh pr checkout*)",
      "Bash(gh project copy*)",
      "Bash(gh repo set-default*)",
      "Bash(gh repo sync*)",
      "Bash(gh workflow run*)",
      "Bash(git commit*)",
      "Bash(git push*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "*.amazonaws.com",
        "*.ansible.com",
        "*.docker.com",
        "*.gitea.com",
        "*.github.com",
        "*.githubusercontent.com",
        "*.gstatic.com",
        "*.hcaptcha.com",
        "*.infinito.example",
        "*.infinito.nexus",
        "*.npmjs.org",
        "*.pythonhosted.org",
        "*.taiga.io",
        "*.windows.net",
        "cybermaster.space",
        "ghcr.io",
        "github.com",
        "infinito.example",
        "infinito.nexus",
        "letsencrypt.org",
        "monogramm.io",
        "pypi.org"
      ],
      "allowAllUnixSockets": true,
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        ".",
        "/tmp",
        "~/.ansible",
        "~/.cache/pip",
        "~/.cache/pre-commit",
        "~/.venvs"
      ],
      "denyRead": [
        "~/.aws",
        "~/.config/gcloud",
        "~/.gnupg",
        "~/.kube",
        "~/.ssh"
      ]
    }
  }
}
