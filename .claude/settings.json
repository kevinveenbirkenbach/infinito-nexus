{
  "env": {
    "GIT_CONFIG_COUNT": "1",
    "GIT_CONFIG_KEY_0": "commit.gpgsign",
    "GIT_CONFIG_VALUE_0": "false"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "WebSearch",
      "WebFetch(domain:*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean*)",
      "Bash(git branch -D*)",
      "Bash(rm -rf*)",
      "Bash(sudo*)",
      "Bash(gh workflow enable*)",
      "Bash(gh workflow disable*)"
    ],
    "ask": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(docker run*)",
      "Bash(gh api*)",
      "Bash(gh workflow run*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "*.amazonaws.com",
        "*.ansible.com",
        "*.docker.com",
        "*.gitea.com",
        "*.github.com",
        "*.githubusercontent.com",
        "*.gstatic.com",
        "*.hcaptcha.com",
        "*.infinito.example",
        "*.infinito.nexus",
        "*.npmjs.org",
        "*.pythonhosted.org",
        "*.taiga.io",
        "cybermaster.space",
        "ghcr.io",
        "github.com",
        "infinito.example",
        "infinito.nexus",
        "letsencrypt.org",
        "monogramm.io",
        "pypi.org"
      ],
      "allowAllUnixSockets": true,
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        ".",
        "/tmp",
        "~/.cache/pre-commit",
        "~/.cache/pip",
        "~/.venvs",
        "~/.ansible"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.gnupg",
        "~/.kube",
        "~/.aws",
        "~/.config/gcloud"
      ]
    }
  }
}
