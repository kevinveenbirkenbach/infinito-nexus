.:53 {
  template IN A {
    match ^${INFINITO_DOMAIN_RE}\.$
    answer "{{ .Name }} 60 IN A ${INFINITO_IP4}"
    fallthrough
  }

  template IN A {
    match ^(.*)\.${INFINITO_DOMAIN_RE}\.$
    answer "{{ .Name }} 60 IN A ${INFINITO_IP4}"
    fallthrough
  }

  template IN AAAA {
    match ^${INFINITO_DOMAIN_RE}\.$
    fallthrough
  }

  template IN AAAA {
    match ^(.*)\.${INFINITO_DOMAIN_RE}\.$
    fallthrough
  }

  forward . 1.1.1.1 8.8.8.8  # noqa: hardcoded-dns-resolver
  log
  errors
}
