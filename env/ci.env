# Base env-file consumed by `docker compose --env-file <this-file> ...` # nocheck: self-path-reference
# in CI and local development. `env.development`, if it exists, is
# layered on top and overrides individual keys.
#
# Convention: every key is preceded by a single-line `# ...` comment
# and carries the `INFINITO_` prefix so it cannot collide with
# generic shell or Ansible-role variables of the same short name.

# IPv4 of the CoreDNS sidecar inside INFINITO_SUBNET (services resolve here).
INFINITO_DNS_IP=172.30.0.53

# Top-level project domain rendered into vhost/cert/test fixtures.
INFINITO_DOMAIN=infinito.example

# INFINITO_DOMAIN escaped for inclusion in regex patterns (literal `.`).
INFINITO_DOMAIN_RE=infinito\.example

# IPv4 of the infinito application container inside INFINITO_SUBNET.
INFINITO_IP4=172.30.0.10
