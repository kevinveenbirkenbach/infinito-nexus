# The .gitignore is the single point of truth for files which should be ignored.
# Add patterns, files and folders to the .gitignore and execute 'make build'
# NEVER TOUCH THE .dockerignore, BECAUSE IT ANYHOW WILL BE OVERWRITTEN

site.retry
*__pycache__
venv
*.log
*.bak
*tree.json
roles/list.json
*.pyc
*.egg-info
build/*
.ruff_cache
.agents
collections/
env.development
logs/
job-logs.txt
.claude/skills
.claude/agents
.claude/commands
.claude/settings.local.json
*.lock
compose/coredns/Corefile
compose/Corefile

# Host shell / editor / tooling state accidentally surfaced inside this working copy
.bash_profile
.bashrc
.gitconfig
.gitmodules
.idea
.mcp.json
.profile
.ripgreprc
.vscode
.zprofile
.zshrc
