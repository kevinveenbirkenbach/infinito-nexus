# The .gitignore is the single point of truth for files which should be ignored.
# Add patterns, files and folders to the .gitignore and execute 'make build'
# NEVER TOUCH THE .dockerignore, BECAUSE IT ANYHOW WILL BE OVERWRITTEN

site.retry
*__pycache__
compose.cache.override.yml
venv
*.log
*.bak
*tree.json
roles/list.json
roles/importer_result.json
*.pyc
*.egg-info
build/*
.ruff_cache
.agents
collections/
env.development
.env
logs/
job-logs.txt
.claude/skills
.claude/agents
.claude/commands
.claude/settings.local.json
*.lock
node_modules/

# No-op for Git (ignored implicitly), but Docker needs .git in its ignore-list — keeps make dockerignore as a pure cat of this file.
.git

# Host shell / editor / tooling state accidentally surfaced inside this working copy
.bash_profile
.bashrc
.gitconfig
.gitmodules
.idea
.mcp.json
.profile
.ripgreprc
.vscode
.zprofile
.zshrc
