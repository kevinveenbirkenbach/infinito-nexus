APP_BASE_URL={{ lookup('tls', application_id, 'url.base') | dotenv_quote }}
CANONICAL_DOMAIN={{ lookup('domain', application_id) | dotenv_quote }}

# Asset hosts: sys-front-inj-css injects `<link rel="stylesheet">` tags
# pointing at the CDN host directly; web-svc-css is the redirect alias.
# The spec accepts either host so the assertion passes both before and
# after the css.* → cdn.* redirect chain resolves.
CSS_BASE_URL={{ lookup('tls', 'web-svc-css', 'url.base') | dotenv_quote }}
CDN_BASE_URL={{ lookup('tls', 'web-svc-cdn', 'url.base') | dotenv_quote }}

# Per-consumer indexing targets: every role declaring
# `services.css.{enabled,shared}` in its meta/services.yml. The css
# spec parameterises one HTML-link assertion per entry; the consumer
# roles suppress the env-services match guard with
# `# nocheck: playwright-service-flag — verified by web-svc-css provider spec`.
CSS_TARGET_ROLES_JSON={{ lookup('roles_with_service', 'css') | to_json | dotenv_quote }}
