APP_BASE_URL={{ lookup('tls', application_id, 'url.base') | dotenv_quote }}
KEYCLOAK_REALM_NAME={{ KEYCLOAK_REALM | dotenv_quote }}
SUPER_ADMIN_USERNAME={{ KEYCLOAK_PERMANENT_ADMIN_USERNAME | dotenv_quote }}
SUPER_ADMIN_PASSWORD={{ KEYCLOAK_PERMANENT_ADMIN_PASSWORD | dotenv_quote }}
ADMIN_USERNAME={{ lookup('users', 'administrator').username | dotenv_quote }}
ADMIN_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}
BIBER_USERNAME={{ lookup('users', 'biber').username | dotenv_quote }}
BIBER_PASSWORD={{ lookup('users', 'biber').password | dotenv_quote }}
CANONICAL_DOMAIN={{ (lookup('applications', application_id).server.domains.canonical | first) | dotenv_quote }}

# Auth-provider exception: the persona stubs in
# files/playwright.spec.js exist purely to satisfy the persona-naming
# lint. Biber and administrator have no app surface to reach here:
# Keycloak IS the auth provider, so explicit-block both. The bespoke
# "master-realm super administrator", "normal-realm administrator",
# and "normal-realm biber" tests cover the persona contract via the
# realm account UI / admin console.
PERSONA_BIBER_BLOCKED=true
PERSONA_ADMINISTRATOR_BLOCKED=true

# Service gate flags rendered for closure.
MATOMO_BASE_URL={{ lookup('tls', 'web-app-matomo', 'url.base') | dotenv_quote }}

# nocheck: persona-required-envs — auth-provider role; persona-flow runners are not used here
# nocheck: playwright-service-gate — auth-provider role; generic persona scenarios are exempt (covered by bespoke realm-account / admin-console tests above)
LOGOUT_SERVICE_ENABLED={{ lookup('config', application_id, 'services.logout.enabled') | string | lower }}
# nocheck: playwright-service-gate — persona drives the OIDC path; LDAP federation is exercised in the LDAP-only matrix variant
LDAP_SERVICE_ENABLED={{ lookup('config', application_id, 'services.ldap.enabled') | string | lower }}
# nocheck: playwright-service-gate — auth-provider role; generic persona scenarios are exempt
MATOMO_SERVICE_ENABLED={{ lookup('config', application_id, 'services.matomo.enabled') | string | lower }}
# nocheck: playwright-service-gate — covered by sys-svc-mail integration tests, not the persona surface
EMAIL_SERVICE_ENABLED={{ lookup('config', application_id, 'services.email.enabled') | string | lower }}
