{% set _moodle_attrs = [
  { "name": "middleName",          "displayName": "Middle name",        "validations": {"length": {"max": 255}}, "permissions": {"view": ["admin","user"], "edit": ["admin","user"]}, "group": "moodle", "multivalued": false },
  { "name": "nickname",            "displayName": "Nickname",            "validations": {"length": {"max": 255}}, "permissions": {"view": ["admin","user"], "edit": ["admin","user"]}, "group": "moodle", "multivalued": false },
  { "name": "phoneNumber",         "displayName": "Phone number",        "validations": {"length": {"max": 64}},  "permissions": {"view": ["admin","user"], "edit": ["admin","user"]}, "group": "moodle", "multivalued": false },
  { "name": "phoneNumberAlt",      "displayName": "Mobile",              "validations": {"length": {"max": 64}},  "permissions": {"view": ["admin","user"], "edit": ["admin","user"]}, "group": "moodle", "multivalued": false },
  { "name": "street",              "displayName": "Street",              "validations": {"length": {"max": 255}}, "permissions": {"view": ["admin","user"], "edit": ["admin","user"]}, "group": "moodle", "multivalued": false },
  { "name": "locality",            "displayName": "City",                "validations": {"length": {"max": 128}}, "permissions": {"view": ["admin","user"], "edit": ["admin","user"]}, "group": "moodle", "multivalued": false },
  { "name": "country",             "displayName": "Country (ISO-3166-1 alpha-2)", "validations": {"length": {"max": 2}},   "permissions": {"view": ["admin","user"], "edit": ["admin","user"]}, "group": "moodle", "multivalued": false },
  { "name": "institution",         "displayName": "Institution",         "validations": {"length": {"max": 255}}, "permissions": {"view": ["admin","user"], "edit": ["admin","user"]}, "group": "moodle", "multivalued": false },
  { "name": "department",          "displayName": "Department",          "validations": {"length": {"max": 255}}, "permissions": {"view": ["admin","user"], "edit": ["admin","user"]}, "group": "moodle", "multivalued": false },
  { "name": "description",         "displayName": "Description",         "validations": {"length": {"max": 1024}},"permissions": {"view": ["admin","user"], "edit": ["admin","user"]}, "group": "moodle", "multivalued": false },
  { "name": "idNumber",            "displayName": "ID number",           "validations": {"length": {"max": 64}},  "permissions": {"view": ["admin","user"], "edit": ["admin","user"]}, "group": "moodle", "multivalued": false },
  { "name": "website",             "displayName": "Website",             "validations": {"length": {"max": 255}}, "permissions": {"view": ["admin","user"], "edit": ["admin","user"]}, "group": "moodle", "multivalued": false },
  { "name": "locale",              "displayName": "Locale",              "validations": {"length": {"max": 16}},  "permissions": {"view": ["admin","user"], "edit": ["admin","user"]}, "group": "moodle", "multivalued": false },
  { "name": "zoneinfo",            "displayName": "Time zone (IANA)",    "validations": {"length": {"max": 64}},  "permissions": {"view": ["admin","user"], "edit": ["admin","user"]}, "group": "moodle", "multivalued": false },
  { "name": "namePhoneticGiven",   "displayName": "Phonetic given name", "validations": {"length": {"max": 255}}, "permissions": {"view": ["admin","user"], "edit": ["admin","user"]}, "group": "moodle", "multivalued": false },
  { "name": "namePhoneticFamily",  "displayName": "Phonetic family name","validations": {"length": {"max": 255}}, "permissions": {"view": ["admin","user"], "edit": ["admin","user"]}, "group": "moodle", "multivalued": false }
] %}
{% set _moodle_group = {
  "name": "moodle",
  "displayHeader": "Moodle profile",
  "displayDescription": "Attributes consumed by Moodle (OIDC + LDAP)."
} %}
{% set _base_attrs = [
  {
    "name": "username",
    "displayName": "${username}",
    "validations": {
      "length": { "min": 3, "max": 255 },
      "pattern": {
        "pattern": "^(?!(?:" ~ KEYCLOAK_RESERVED_USERNAMES_REGEX | replace('\\', '\\\\') ~ ")$)[a-z0-9]+$",
        "error-message": "Username is reserved or contains invalid characters. Only lowercase letters (a–z) and digits (0–9) are allowed."
      }
    },
    "annotations": {},
    "permissions": {"view": ["admin","user"], "edit": ["admin","user"]},
    "multivalued": false
  },
  {
    "name": "email",
    "displayName": "${email}",
    "validations": {"email": {}, "length": {"max": 255}},
    "required": {"roles": ["user"]},
    "permissions": {"view": ["admin","user"], "edit": ["admin","user"]},
    "multivalued": false
  },
  {
    "name": "firstName",
    "displayName": "${firstName}",
    "validations": {"length": {"max": 255}, "person-name-prohibited-characters": {}},
    "required": {"roles": ["user"]},
    "permissions": {"view": ["admin","user"], "edit": ["admin","user"]},
    "multivalued": false
  },
  {
    "name": "lastName",
    "displayName": "${lastName}",
    "validations": {"length": {"max": 255}, "person-name-prohibited-characters": {}},
    "required": {"roles": ["user"]},
    "permissions": {"view": ["admin","user"], "edit": ["admin","user"]},
    "multivalued": false
  },
  {
    "name": LDAP.USER.ATTRIBUTES.SSH_PUBLIC_KEY,
    "displayName": "SSH Public Key",
    "validations": {},
    "annotations": {},
    "permissions": {"view": ["admin","user"], "edit": ["admin","user"]},
    "group": "user-metadata",
    "multivalued": true
  }
] %}
{% set user_profile = {
  "attributes": _base_attrs + (_moodle_attrs if KEYCLOAK_MOODLE_ENABLED | bool else []),
  "groups": [
    {
      "name": "user-metadata",
      "displayHeader": "User metadata",
      "displayDescription": "Attributes, which refer to user metadata"
    }
  ] + ([_moodle_group] if KEYCLOAK_MOODLE_ENABLED | bool else [])
} %}
"org.keycloak.userprofile.UserProfileProvider": [
  {
    "providerId": "declarative-user-profile",
    "name": "declarative-user-profile",
    "subComponents": {},
    "config": {
      "kc.user.profile.config": [{{ (user_profile | to_json) | to_json }}]
    }
  }
]
