server:
  verbosity: 1
  interface: 0.0.0.0
{% raw %}{{- '  interface: ::0' if SUBNET6 }}
{% endraw %}
  logfile: ""
  do-ip4: yes
  do-ip6: {% raw %}{{ 'yes' if SUBNET6 else 'no' }}{% endraw %}

  do-udp: yes
  do-tcp: yes
  do-daemonize: no
  access-control: {% raw %}{{ SUBNET }}{% endraw %} allow
{% raw %}{%- if SUBNET6 %}
  access-control: {{ SUBNET6 }} allow
{%- endif %}{% endraw %}

  directory: "/etc/unbound"
  username: unbound
  auto-trust-anchor-file: trusted-key.key
  root-hints: "/etc/unbound/root.hints"
  hide-identity: yes
  hide-version: yes
  cache-min-ttl: 300

remote-control:
  control-enable: yes
  control-interface: /run/unbound.control.sock
{% if MAILU_UNBOUND_FORWARD_DNS | bool %}

# WSL2/DinD: iterative resolution via root-hints is not supported in nested
# Docker. Forward all queries to public resolvers instead.
# Enable by setting MAILU_UNBOUND_FORWARD_DNS: true in your inventory.
forward-zone:
  name: "."
{% for resolver in NETWORK_PUBLIC_DNS_RESOLVERS %}
  forward-addr: {{ resolver }}
{% endfor %}
{% endif %}
