APP_BASE_URL={{ lookup('tls', application_id, 'url.base') | dotenv_quote }}
CANONICAL_DOMAIN={{ lookup('domain', application_id) | dotenv_quote }}
ADMIN_USERNAME={{ lookup('users', 'administrator').username | dotenv_quote }}
ADMIN_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}
BIBER_USERNAME={{ lookup('users', 'biber').username | dotenv_quote }}
BIBER_PASSWORD={{ lookup('users', 'biber').password | dotenv_quote }}

# Web-svc-logout has no user-facing surface; the role only ships the
# universal-logout JS that is injected into every consumer role. The
# persona stubs exist to satisfy the persona-naming lint; explicit-block
# both because they have no role surface to land on.
PERSONA_BIBER_BLOCKED=true
PERSONA_ADMINISTRATOR_BLOCKED=true

# Injection-target list: every role declaring
# `services.logout.{enabled,shared}`. The logout spec parameterises
# one injection-presence assertion per entry.
LOGOUT_TARGET_ROLES_JSON={{ lookup('roles_with_service', 'logout') | to_json | dotenv_quote }}
