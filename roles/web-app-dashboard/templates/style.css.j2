.card-img-top i {
    filter: drop-shadow(4px 4px 4px rgba(var(--color-rgb-01-23), 0.6));
}

/* The dashboard cards use stretched-link buttons as full-card overlays.
   Disabling hover filters here keeps the hover target stable across the card. */
.card .btn.stretched-link:hover,
.card .btn.stretched-link:focus,
.card .btn.stretched-link:active {
    filter: none;
}

.kanban-table-body .kanban-uses-box {
    background-color: var(--color-01-81);
}

.kanban-swimlane-title {
    border-bottom: none;
}

.navbar-toggler {
    background-color:   rgba(var(--color-rgb-01-75), 0.9);
    border-color:       var(--color-01-67)
}

.sys-ctl-alm-info {
    --bs-sys-ctl-alm-color: var(--color-03-14);
    --bs-sys-ctl-alm-bg: var(--color-01-86);
}
