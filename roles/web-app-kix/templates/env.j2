NAME=kix
INITIAL_ADMIN_PW={{ KIX_INITIAL_ADMIN_PW | dotenv_quote }}

FRONTEND_PORT={{ lookup('config', application_id, 'services.kix.ports.local.http') }}
BACKEND_PORT=20000
SSP_PORT=20002
FRONTEND_PORT_SSL=20444
BACKEND_PORT_SSL=20443
SSP_PORT_SSL=20445

KIXDB_HOST=db
KIXDB_DBMS=postgresql
KIXDB_DATABASE={{ KIX_DB_NAME }}
KIXDB_USER={{ KIX_DB_USER }}
KIXDB_PASSWORD={{ KIX_DB_PASSWORD | dotenv_quote }}

POSTGRES_DB={{ KIX_DB_NAME }}
POSTGRES_USER={{ KIX_DB_USER }}
POSTGRES_PASSWORD={{ KIX_DB_PASSWORD | dotenv_quote }}

LOG_LEVEL={% if MODE_DEBUG | bool %}3{% else %}2{% endif %}

STOP_GRACE_PERIOD=60s

{% set email = lookup('email', application_id) %}
{% if email.enabled | bool %}
SMTP_HOST={{ email.host }}
SMTP_PORT={{ email.port }}
SMTP_USER={{ email.username }}
SMTP_PASSWORD={{ email.password | dotenv_quote }}
SMTP_FROM=no-reply@{{ email.domain }}
{% endif %}
