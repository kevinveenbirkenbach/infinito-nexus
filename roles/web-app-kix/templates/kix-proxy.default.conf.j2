server_tokens off;

map $http_sec_websocket_key $http_upgrade {
    "" "";
    default "websocket";
}

map $http_sec_websocket_key $connection_upgrade {
    "" $http_connection;
    default "upgrade";
}

{{ NETWORK_DOCKER_DNS_NGINX_DIRECTIVE }}

server {
    listen 80;
    server_name _;

    # Strip client-supplied Remote-User; only the OAuth2-proxy hop is allowed to set it (below).
    proxy_set_header Remote-User "";

    client_max_body_size 64m;
    proxy_read_timeout    300s;
    proxy_send_timeout    300s;

    location / {
        proxy_set_header Host                $host;
        proxy_set_header X-Real-IP           $remote_addr;
        proxy_set_header X-Forwarded-For     $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto   $scheme;
        proxy_set_header X-Forwarded-User    $http_x_forwarded_user;
        proxy_set_header Remote-User         $http_x_forwarded_user;
        proxy_set_header Upgrade             $http_upgrade;
        proxy_set_header Connection          $connection_upgrade;
        proxy_http_version 1.1;
        set $upstream_kix_frontend http://frontend:3000;
        proxy_pass $upstream_kix_frontend;
    }
}
