  # Mattermost — application and Go runtime metrics.
  # Scraped via internal metrics listener to bypass nginx/OAuth2 proxy.
  # Requires MM_METRICSSETTINGS_ENABLE=true and MM_METRICSSETTINGS_LISTENADDRESS (set in env.j2 when enabled).
  - job_name: "mattermost"
    scheme: http
    metrics_path: /metrics
    static_configs:
      - targets: ["{{ native_prometheus_application_id | native_metrics_target(ports) }}"]
        labels:
          app: "{{ native_prometheus_application_id }}"
