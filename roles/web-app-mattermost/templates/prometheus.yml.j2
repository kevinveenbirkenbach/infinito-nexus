  # Mattermost — application and Go runtime metrics.
  # Requires MM_METRICSSETTINGS_ENABLE=true in the Mattermost environment config.
  # Enable via native_metrics.enabled: true in inventory.
  - job_name: "mattermost"
    scheme: {{ lookup('tls', native_prometheus_application_id, 'protocols.web') }}
    metrics_path: /metrics
    tls_config:
      insecure_skip_verify: {{ not (TLS_ENABLED | bool) }}
    static_configs:
      - targets: ["{{ lookup('domain', native_prometheus_application_id) }}"]
        labels:
          app: "{{ native_prometheus_application_id }}"
