<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
{% if FEDIWALL_WALLS | length == 1 %}
  <meta http-equiv="refresh" content="0; url=./{{ FEDIWALL_WALLS[0].slug }}/">
  <link rel="canonical" href="./{{ FEDIWALL_WALLS[0].slug }}/">
  <title>Redirecting to {{ FEDIWALL_WALLS[0].config.title }}…</title>
</head>
<body>
  <p><a href="./{{ FEDIWALL_WALLS[0].slug }}/">Open {{ FEDIWALL_WALLS[0].config.title }}</a></p>
</body>
{% else %}
  <title>Fediwalls on {{ DOMAIN_PRIMARY }}</title>
  <link rel="shortcut icon" type="image/png" href="./favicon.png">
  <style>
    body { font: 16px/1.5 system-ui, sans-serif; margin: 2rem auto; max-width: 40rem; padding: 0 1rem; color: #222; background: #fafafa; }
    h1 { font-size: 1.5rem; margin-bottom: 1.5rem; }
    ul { list-style: none; padding: 0; }
    li { margin: 0.5rem 0; }
    a { color: #1a73e8; text-decoration: none; padding: 0.5rem 0.75rem; border: 1px solid #ddd; border-radius: 0.375rem; display: inline-block; background: #fff; }
    a:hover { background: #f0f4ff; border-color: #1a73e8; }
    @media (prefers-color-scheme: dark) {
      body { color: #eee; background: #121212; }
      a { color: #82b1ff; background: #1e1e1e; border-color: #333; }
      a:hover { background: #1f2a44; border-color: #82b1ff; }
    }
  </style>
</head>
<body>
  <h1>Fediwalls on {{ DOMAIN_PRIMARY }}</h1>
  <ul>
{% for wall in FEDIWALL_WALLS %}
    <li><a href="./{{ wall.slug }}/">{{ wall.config.title }}</a></li>
{% endfor %}
  </ul>
</body>
{% endif %}
</html>
