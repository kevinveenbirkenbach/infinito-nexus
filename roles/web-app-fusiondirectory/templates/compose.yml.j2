{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
  fusiondirectory:
    image: "{{ FUSIONDIRECTORY_IMAGE }}:{{ FUSIONDIRECTORY_VERSION }}"
    container_name: {{ FUSIONDIRECTORY_CONTAINER }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.fusiondirectory.ports.local.http') }}:80"
    environment:
      FUSIONDIRECTORY_ADMIN_USER: "{{ lookup('users', 'administrator').username }}"
      FUSIONDIRECTORY_ADMIN_PASS: "{{ lookup('users', 'administrator').password }}"
      LDAP_HOST: "{{ lookup('config', 'svc-db-openldap', 'services.openldap.name') }}"
      LDAP_ADMIN_DN: "{{ LDAP.DN.ADMINISTRATOR.DATA }}"
      LDAP_ADMIN_PASS: "{{ LDAP.BIND_CREDENTIAL }}"
      LDAP_BASE_DN: "{{ LDAP.DN.ROOT }}"
    volumes:
      - data:/assets/fusiondirectory
{% include 'roles/sys-svc-container/templates/healthcheck/curl.yml.j2' %}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

{{ lookup('applications') | compose_volumes(
    application_id,
    extra_volumes={'data': {'name': FUSIONDIRECTORY_VOLUME}}
) }}
{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
