APP_BASE_URL={{ lookup('tls', 'web-app-dashboard', 'url.base') }}
OIDC_ISSUER_URL={{ OIDC.CLIENT.ISSUER_URL | dotenv_quote }}
PIXELFED_BASE_URL={{ lookup('tls', 'web-app-pixelfed', 'url.base') | dotenv_quote }}
# First validate the default OIDC self-provisioning path with a non-reserved
# username before exercising the administrator account bootstrap.
LOGIN_USERNAME_FIRST={{ lookup('users', PIXELFED_PLAYWRIGHT_FIRST_USER_KEY).username | dotenv_quote }}
LOGIN_PASSWORD_FIRST={{ lookup('users', PIXELFED_PLAYWRIGHT_FIRST_USER_KEY).password | dotenv_quote }}
# The second run covers the bootstrapped administrator, which cannot be created
# through Pixelfed's first-time OIDC registration flow because the name is reserved.
LOGIN_USERNAME_SECOND={{ lookup('users', PIXELFED_PLAYWRIGHT_SECOND_USER_KEY).username | dotenv_quote }}
LOGIN_PASSWORD_SECOND={{ lookup('users', PIXELFED_PLAYWRIGHT_SECOND_USER_KEY).password | dotenv_quote }}

# Service gate flags rendered for req 019 closure.
MATOMO_BASE_URL={{ lookup('tls', 'web-app-matomo', 'url.base') | dotenv_quote }}

OIDC_SERVICE_ENABLED={{ lookup('config', application_id, 'services.oidc.enabled') | string | lower }}
LOGOUT_SERVICE_ENABLED={{ lookup('config', application_id, 'services.logout.enabled') | string | lower }}
MATOMO_SERVICE_ENABLED={{ lookup('config', application_id, 'services.matomo.enabled') | string | lower }}
# nocheck: playwright-service-gate — covered by sys-svc-mail integration tests, not the persona surface
EMAIL_SERVICE_ENABLED={{ lookup('config', application_id, 'services.email.enabled') | string | lower }}
