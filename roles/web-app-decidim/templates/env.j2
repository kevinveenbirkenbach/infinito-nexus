# Rails environment
RAILS_ENV={{ ENVIRONMENT }}
RAILS_LOG_TO_STDOUT={{ MODE_DEBUG | lower }}
RAILS_SERVE_STATIC_FILES=true

# Application
SECRET_KEY_BASE={{ DECIDIM_SECRET_KEY_BASE }}
DATABASE_URL=postgresql://{{ lookup('database', application_id, 'username') }}:{{ lookup("database", application_id, "password") | urlencode }}@{{ lookup('database', application_id, 'host') }}:{{ lookup('database', application_id, 'port') }}/{{ lookup('database', application_id, 'name') }}?sslmode=disable
REDIS_URL=redis://redis:6379/0

# Organisation
DECIDIM_APPLICATION_NAME="{{ DECIDIM_ORGANIZATION_NAME }}"
DECIDIM_FORCE_SSL={{ TLS_ENABLED | lower }}
DECIDIM_ALLOW_OPEN_REDIRECTS=false
PORT=3000
RAILS_HOSTS={{ lookup("tls", application_id, "url.base") | regex_replace("https?://", "") }}
APPLICATION_HOST={{ lookup('tls', application_id, 'url.base') }}

# Logging
LOG_LEVEL={% if MODE_DEBUG | bool %}debug{% else %}info{% endif %}

{% if SYSTEM_EMAIL_ENABLED | bool %}
# SMTP
SMTP_ADDRESS={{ SYSTEM_EMAIL_HOST }}
SMTP_PORT={{ SYSTEM_EMAIL_PORT }}
SMTP_USERNAME={{ users['no-reply'].email }}
SMTP_PASSWORD={{ users['no-reply'].tokens['web-app-mailu'] | dotenv_quote }}
SMTP_AUTHENTICATION=login
SMTP_STARTTLS_AUTO={{ TLS_ENABLED | lower }}
MAILER_SENDER="{{ DECIDIM_ORGANIZATION_NAME }} <{{ users['no-reply'].email }}>"
{% endif %}

{% if DECIDIM_OIDC_ENABLED | bool %}
# OIDC / Keycloak SSO
OIDC_ENABLED=true
OIDC_CLIENT_ID={{ DECIDIM_OIDC_CLIENT_ID }}
OIDC_CLIENT_SECRET={{ DECIDIM_OIDC_CLIENT_SECRET }}
OIDC_ISSUER={{ DECIDIM_OIDC_ISSUER }}
OIDC_AUTHORIZE_URL={{ DECIDIM_OIDC_AUTHORIZE_URL }}
OIDC_TOKEN_URL={{ DECIDIM_OIDC_TOKEN_URL }}
OIDC_USER_INFO_URL={{ DECIDIM_OIDC_USER_INFO_URL }}
{% endif %}

# SSL
SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
PYTHONHTTPSVERIFY={{ TLS_ENABLED | ternary(1,0) }}
GIT_SSL_NO_VERIFY={{ TLS_ENABLED | ternary(0,1) }}
