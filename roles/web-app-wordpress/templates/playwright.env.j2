APP_BASE_URL={{ lookup('tls', 'web-app-dashboard', 'url.base') | dotenv_quote }}
KEYCLOAK_BASE_URL={{ lookup('tls', 'web-app-keycloak', 'url.base') | dotenv_quote }}
KEYCLOAK_REALM_NAME={{ OIDC.CLIENT.REALM | dotenv_quote }}
WORDPRESS_BASE_URL={{ lookup('tls', application_id, 'url.base') | dotenv_quote }}
OIDC_ISSUER_URL={{ OIDC.CLIENT.ISSUER_URL | dotenv_quote }}
SUPER_ADMIN_USERNAME={{ lookup('config', 'web-app-keycloak', 'accounts.system.username') | dotenv_quote }}
SUPER_ADMIN_PASSWORD={{ lookup('config', 'web-app-keycloak', 'credentials.administrator_password') | dotenv_quote }}
ADMIN_USERNAME={{ lookup('users', 'administrator').username | dotenv_quote }}
ADMIN_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}
BIBER_USERNAME={{ lookup('users', 'biber').username | dotenv_quote }}
BIBER_PASSWORD={{ lookup('users', 'biber').password | dotenv_quote }}
CANONICAL_DOMAIN={{ (lookup('applications', application_id).server.domains.canonical | first) | dotenv_quote }}
RBAC_GROUP_PATH_PREFIX={{ ('/' ~ (RBAC.GROUP.NAME | trim('/')) ~ '/' ~ application_id ~ '/') | dotenv_quote }}

# --- Service gate flags (requirement 006) -----------------------------------
# Each flag is "true" or "false" literally. Sources are uniform across
# roles: we use `lookup('service', '<name>').required` for shared services
# and `group_names` membership for web-app deps. The shared helper
# `tests/service-gating.js` reads these variables and hard-fails on any
# unknown service name.
OIDC_SERVICE_ENABLED={{ 'true' if (lookup('service', 'oidc').required | default(false) | bool) else 'false' }}
LDAP_SERVICE_ENABLED={{ 'true' if (lookup('service', 'ldap').required | default(false) | bool) else 'false' }}
DASHBOARD_SERVICE_ENABLED={{ 'true' if (lookup('config', application_id, 'compose.services.dashboard.enabled') | default(false) | bool) else 'false' }}
# Discourse is a web-app (not a shared-service key); gate on whether
# web-app-discourse is deployed on this host.
DISCOURSE_SERVICE_ENABLED={{ 'true' if ('web-app-discourse' in (group_names | default([]))) else 'false' }}

# --- WordPress Multisite (requirement 005) ----------------------------------
# When "true" the spec runs the Multisite scenarios against multiple
# canonical domains. When "false" it runs the Single-Site scenarios that
# were in place before requirement 005. The source of truth is
# `compose.services.wordpress.multisite.enabled` in the role config.
WORDPRESS_MULTISITE_ENABLED={{ 'true' if (lookup('config', application_id, 'compose.services.wordpress.multisite.enabled') | default(false) | bool) else 'false' }}

# --- WP-Discourse round-trip (requirement 007) ------------------------------
DISCOURSE_BASE_URL={{ (lookup('tls', 'web-app-discourse', 'url.base') | dotenv_quote) if ('web-app-discourse' in (group_names | default([]))) else '""' }}
DISCOURSE_API_KEY={{ (vault_discourse_api_key | default('')) | dotenv_quote }}
DISCOURSE_API_USERNAME={{ 'system' | dotenv_quote }}
