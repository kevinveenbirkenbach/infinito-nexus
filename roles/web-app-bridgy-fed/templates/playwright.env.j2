APP_BASE_URL={{ lookup('tls', application_id, 'url.base') | dotenv_quote }}
CANONICAL_DOMAIN={{ (lookup('applications', application_id).server.domains.canonical | first) | dotenv_quote }}

# Service gate flags (requirement 006). Bridgy Fed authenticates users
# via their fediverse / atproto credentials at the source platform; the
# role has no local user accounts, no in-app authorisation tier, and no
# OIDC or LDAP integration. The exception is documented in README.md
# per requirement 013. Both flags MUST stay literal "false".
OIDC_SERVICE_ENABLED=false
LDAP_SERVICE_ENABLED=false
