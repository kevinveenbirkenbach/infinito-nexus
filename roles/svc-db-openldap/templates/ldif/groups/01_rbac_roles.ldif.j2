{% for dn, entry in (lookup('applications') | build_ldap_role_entries(OPENLDAP_USERS, LDAP, group_names)).items() %}

dn: {{ dn }}
{% for oc in entry.objectClass %}
objectClass: {{ oc }}
{% endfor %}
{% if entry.gidNumber is defined %}
gidNumber: {{ entry.gidNumber }}
{% endif %}
cn: {{ entry.cn }}
{% if entry.description is defined and entry.description %}
description: {{ entry.description }}
{% endif %}
{% if entry.memberUid is defined %}
{% for uid in entry.memberUid %}
memberUid: {{ uid }}
{% endfor %}
{% endif %}
{% if entry.member is defined %}
{% for m in entry.member %}
member: {{ m }}
{% endfor %}
{% endif %}

{% endfor %}
