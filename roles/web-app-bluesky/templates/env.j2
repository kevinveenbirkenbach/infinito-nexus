# General
PDS_HOSTNAME="{{ BLUESKY_API_DOMAIN }}"
PDS_CRAWLERS=https://bsky.network
LOG_ENABLED={{ MODE_DEBUG | string | lower }}
PDS_BLOBSTORE_DISK_LOCATION={{ BLUESKY_PDS_BLOBSTORE_LOCATION }}
PDS_DATA_DIRECTORY={{ BLUESKY_PDS_DATA_DIR }}
PDS_BLOB_UPLOAD_LIMIT=52428800
PDS_DID_PLC_URL=https://plc.directory

{# The login-broker auto-provisions PDS accounts on first SSO visit
   (see files/login-broker/server.js → pdsCreateAccount). Without this
   override PDS rejects createAccount with `InvalidInviteCode` because
   the upstream default flips invite-required on. We disable the gate
   so Keycloak-authenticated users get a PDS account without the
   operator having to mint and inject invite codes. #}
PDS_INVITE_REQUIRED=false

# See https://mattdyson.org/blog/2024/11/self-hosting-bluesky-pds/
# `BLUESKY_PDS_HANDLE_DOMAIN` is `DOMAIN_PRIMARY` with disallowed TLDs
# remapped to `.app` (see vars/main.yml). PDS_SERVICE_HANDLE_DOMAINS MUST
# match what the broker writes into the handle so PDS recognises the
# domain as one it issues for.
PDS_SERVICE_HANDLE_DOMAINS=".{{ BLUESKY_PDS_HANDLE_DOMAIN }}"
PDS_SERVICE_DID="did:web:{{ BLUESKY_API_DOMAIN }}"

{% set email = lookup('email', application_id) %}
{% if email.enabled | bool %}
# Email
PDS_ADMIN_EMAIL="{{ BLUESKY_ADMIN_EMAIL }}"
PDS_EMAIL_SMTP_URL=smtps://{{ email.username }}:{{ email.password }}@{{ email.host }}:{{ email.port }}/
PDS_EMAIL_FROM_ADDRESS={{ email['from'] }}
{% endif %}

# Credentials
PDS_JWT_SECRET="{{ BLUESKY_JWT_SECRET }}"
PDS_ADMIN_PASSWORD={{ BLUESKY_ADMIN_PASSWORD | dotenv_quote }}
PDS_PLC_ROTATION_KEY_K256_PRIVATE_KEY_HEX="{{ BLUESKY_ROTATION_KEY }}"

# View
PDS_BSKY_APP_VIEW_URL={{ BLUESKY_VIEW_URL }}
PDS_BSKY_APP_VIEW_DID={{ BLUESKY_VIEW_DID }}

# Report
# nocheck: url
PDS_REPORT_SERVICE_URL=https://mod.bsky.app
PDS_REPORT_SERVICE_DID=did:plc:ar7c4by46qjdydhdevvrndac
