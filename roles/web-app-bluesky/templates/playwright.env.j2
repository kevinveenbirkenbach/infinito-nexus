APP_BASE_URL={{ lookup('tls', application_id, 'url.base') }}
BLUESKY_BASE_URL={{ lookup('tls', application_id, 'url.base') | dotenv_quote }}
OIDC_ISSUER_URL={{ OIDC.CLIENT.ISSUER_URL | dotenv_quote }}
ADMIN_USERNAME={{ lookup('users', 'administrator').username | dotenv_quote }}
ADMIN_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}
CANONICAL_DOMAIN={{ (lookup('applications', application_id).server.domains.canonical | first) | dotenv_quote }}

# Service gate flags (requirement 006). Bluesky's OIDC integration
# is the variant-A+ login-broker (see roles/web-app-bluesky/files/login-broker/).
# The OIDC marker keys off services.oauth2.enabled because the
# oauth2-proxy sidecar is the user-facing OIDC entry point. The
# LDAP marker keys off services.ldap.enabled (set by the LDAP
# variant in meta/variants.yml). RBAC is intentionally not mappable
# (PDS knows only "account exists / does not exist") and is documented
# as a SSO/RBAC exception in README.md per lifecycle.md.
OIDC_SERVICE_ENABLED={{ lookup('config', application_id, 'services.oauth2.enabled') | string | lower }}
LDAP_SERVICE_ENABLED={{ lookup('config', application_id, 'services.ldap.enabled') | string | lower }}

NODE_TLS_REJECT_UNAUTHORIZED=0
