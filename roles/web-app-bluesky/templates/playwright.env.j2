APP_BASE_URL={{ lookup('tls', application_id, 'url.base') }}
BLUESKY_BASE_URL={{ lookup('tls', application_id, 'url.base') | dotenv_quote }}
CANONICAL_DOMAIN={{ (lookup('applications', application_id).server.domains.canonical | first) | dotenv_quote }}

# Service gate flags (requirement 006). Bluesky's PDS has no in-app
# role concept beyond "account exists / does not exist", so the
# RBAC integration is a documented exception per requirement 013
# and lifecycle.md (see README.md). The OIDC and LDAP integrations
# are 🛠️ glue paths through a Keycloak event-listener bridge that
# auto-provisions PDS accounts; until that SPI ships, both flags
# stay literal "false" so the spec exercises only the baseline
# reachability scenarios.
OIDC_SERVICE_ENABLED=false
LDAP_SERVICE_ENABLED=false

NODE_TLS_REJECT_UNAUTHORIZED=0
