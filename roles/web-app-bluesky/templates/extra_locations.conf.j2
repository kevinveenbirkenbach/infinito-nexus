# Injected by web-app-bluesky (same pattern as web-app-yourls).
# Exposes a same-origin /config to avoid CORS when the social-app
# fetches config. The `resolver` + variable form below is required so
# nginx defers DNS for the public `ip.bsky.app` / `bsky.app`
# upstreams to runtime — without it `nginx -t` refuses to start
# because the openresty container can't resolve those hosts at
# config-load time.
location = /config {
    resolver {{ NETWORK_PUBLIC_DNS_RESOLVERS | join(' ') }} ipv6={{ NETWORK_IPV6_ENABLED | on_off }} valid=300s;
    set $up_host "{{ BLUESKY_CONFIG_UPSTREAM_URL | regex_replace('^https?://', '') | regex_replace('/.*$', '') }}";
    set $bluesky_config_upstream "{{ BLUESKY_CONFIG_UPSTREAM_URL }}";
    proxy_pass $bluesky_config_upstream;
    proxy_set_header Host $up_host;
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_ssl_server_name on;

    {# Access Control Allow Configurations #}
    proxy_hide_header Access-Control-Allow-Origin;
    {% include 'roles/sys-svc-proxy/templates/headers/access_control_allow.conf.j2' %}
}

location = /ipcc {
    resolver {{ NETWORK_PUBLIC_DNS_RESOLVERS | join(' ') }} ipv6={{ NETWORK_IPV6_ENABLED | on_off }} valid=300s;
    set $up_host "bsky.app";
    set $bluesky_ipcc_upstream "https://bsky.app/ipcc";
    proxy_pass $bluesky_ipcc_upstream;
    proxy_set_header Host $up_host;
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_ssl_server_name on;
    {# Access Control Allow Configurations #}
    proxy_hide_header Access-Control-Allow-Origin;
    {% include 'roles/sys-svc-proxy/templates/headers/access_control_allow.conf.j2' %}
}
