# MINIO
MINIO_ROOT_USER={{ lookup('users', 'administrator').username }}
MINIO_ROOT_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}

# Good practice behind proxies. Kept unconditional so the Console
# emits proxy-aware redirect URLs regardless of which auth variant the
# matrix-deploy is exercising.
MINIO_SERVER_URL={{ MINIO_API_URL }}
MINIO_BROWSER_REDIRECT_URL={{ MINIO_CONSOLE_URL }}

# OIDC IdP registration is intentionally NOT in env vars. The
# anonymous `MINIO_IDENTITY_OPENID_*` form registers the IdP as the
# nameless `(default)` entry, which the MinIO Console's
# `/api/v1/login` endpoint omits from `redirectRules`, so the SSO
# button never appears. The named-prefix form
# `MINIO_IDENTITY_OPENID_<NAME>_*` is rejected by the current MinIO
# release as `unknown environment variable`. The role registers the
# IdP via `mc idp openid add minio keycloak ...` after IAM init
# instead; that path produces a named provider, populates
# `redirectRules`, and renders the SSO button on the Console login
# page. See `tasks/main.yml`.

{% if MINIO_LDAP_ENABLED | bool %}
# =========================
# LDAP Authentication
# =========================
# MinIO authorises federated users by mapping an LDAP group DN onto a
# MinIO policy via `mc admin policy attach`. Configure the policies
# out-of-band; this block only wires the directory binding.
MINIO_IDENTITY_LDAP_SERVER_ADDR={{ LDAP.SERVER.DOMAIN }}:{{ LDAP.SERVER.PORT }}

# Treat empty SECURITY as plain LDAP, TLS/SSL as encrypted.
MINIO_IDENTITY_LDAP_SERVER_INSECURE={{ ('off' if (LDAP.SERVER.SECURITY | upper) in ['TLS','SSL'] else 'on') }}
MINIO_IDENTITY_LDAP_SERVER_STARTTLS={{ ('on' if (LDAP.SERVER.SECURITY | upper) == 'TLS' else 'off') }}
MINIO_IDENTITY_LDAP_TLS_SKIP_VERIFY=off

# Service-account bind for user lookup.
MINIO_IDENTITY_LDAP_LOOKUP_BIND_DN={{ LDAP.DN.ADMINISTRATOR.DATA }}
MINIO_IDENTITY_LDAP_LOOKUP_BIND_PASSWORD={{ LDAP.BIND_CREDENTIAL | dotenv_quote }}

# User and group search.
MINIO_IDENTITY_LDAP_USER_DN_SEARCH_BASE_DN={{ LDAP.DN.ROOT }}
MINIO_IDENTITY_LDAP_USER_DN_SEARCH_FILTER=({{ LDAP.USER.ATTRIBUTES.ID }}=%s)
MINIO_IDENTITY_LDAP_GROUP_SEARCH_BASE_DN={{ LDAP.DN.ROOT }}
MINIO_IDENTITY_LDAP_GROUP_SEARCH_FILTER=(&(objectClass=groupOfNames)(member=%d))
{% endif %}