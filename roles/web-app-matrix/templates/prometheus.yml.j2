  # Matrix Synapse — server and federation metrics.
  # Requires enable_metrics: true in homeserver.yaml.
  # Enable via native_metrics.enabled: true in inventory.
  # Scraped via a dedicated internal metrics listener (not via nginx/OAuth2 proxy),
  # so prometheus reaches it at host.docker.internal:PORT rather than the public domain.
  - job_name: "matrix-synapse"
    scheme: http
    metrics_path: /_synapse/metrics
    static_configs:
      - targets: ["{{ native_prometheus_application_id | native_metrics_target(ports) }}"]
        labels:
          app: "{{ native_prometheus_application_id }}"
