server {
    server_name {{ domain }};
    # Exposes the Ansible role ID as an nginx variable so Lua metrics handlers
    # can attach the 'app' label required by the monitoring ACs.
    set $app_id "{{ application_id }}";
    # Synapse container name — used by /healthz/live to query Docker health state.
    # Empty string disables the Docker dict lookup; the HTTP probe still runs.
    set $container_name "{{ lookup('config', application_id, 'compose.services.synapse.name', '') }}";
    {% include 'roles/sys-front-tls/templates/nginx_ssl_header.j2' %}

    # For the federation port
    listen {{ MATRIX_SYNAPSE_LISTEN_FLAGS }};
    listen [::]:{{ MATRIX_SYNAPSE_LISTEN_FLAGS }};

    {% include 'roles/sys-front-inj-all/templates/server.conf.j2'%}

    {% include 'roles/sys-svc-proxy/templates/location/html.conf.j2' %}

    {% include 'roles/sys-svc-proxy/templates/location/upload.conf.j2' %}

  {% include 'roles/sys-svc-proxy/templates/location/prometheus.conf.j2' %}
}
