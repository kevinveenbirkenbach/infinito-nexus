APP_BASE_URL={{ lookup('tls', application_id, 'url.base') | dotenv_quote }}
CANONICAL_DOMAIN={{ lookup('domain', application_id) | dotenv_quote }}
PROMETHEUS_BASE_URL={{ lookup('tls', application_id, 'url.base') | dotenv_quote }}
OIDC_ISSUER_URL={{ OIDC.CLIENT.ISSUER_URL | dotenv_quote }}
ADMIN_USERNAME={{ lookup('users', 'administrator').username | dotenv_quote }}
ADMIN_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}
BIBER_USERNAME={{ lookup('users', 'biber').username | dotenv_quote }}
BIBER_PASSWORD={{ lookup('users', 'biber').password | dotenv_quote }}

# Prometheus is admin-only via oauth2-proxy allowed_groups; biber lacks the admin role, the proxy denies, and biber has no surface to drive.
PERSONA_BIBER_BLOCKED=true

# With oauth2-proxy disabled, prometheus is direct-accessible and admin has no logout to click; collapse to BLOCKED for a clean skip.
PERSONA_ADMINISTRATOR_BLOCKED={{ (not (lookup('config', application_id, 'services.oauth2.enabled') | bool)) | string | lower }}

# Scrape-target list: every role declaring `services.prometheus.{enabled,shared}`. The spec parameterises one `up=1` assertion per entry.
PROMETHEUS_TARGET_ROLES_JSON={{ lookup('roles_with_service', 'prometheus') | to_json | dotenv_quote }}

# Service gate flags rendered for closure.
MATOMO_BASE_URL={{ lookup('tls', 'web-app-matomo', 'url.base') | dotenv_quote }}

OIDC_SERVICE_ENABLED={{ lookup('config', application_id, 'services.oidc.enabled') | string | lower }}
OAUTH2_SERVICE_ENABLED={{ lookup('config', application_id, 'services.oauth2.enabled') | string | lower }}
LOGOUT_SERVICE_ENABLED={{ lookup('config', application_id, 'services.logout.enabled') | string | lower }}
MATOMO_SERVICE_ENABLED={{ lookup('config', application_id, 'services.matomo.enabled') | string | lower }}
# nocheck: playwright-service-gate — covered by sys-svc-mail integration tests, not the persona surface
EMAIL_SERVICE_ENABLED={{ lookup('config', application_id, 'services.email.enabled') | string | lower }}
