# Alertmanager configuration — auto-generated by Ansible
# DO NOT edit manually; update roles/web-app-prometheus/templates/alertmanager.yml.j2

global:
  smtp_smarthost: "{{ SYSTEM_EMAIL_HOST }}:{{ SYSTEM_EMAIL_PORT }}"
  smtp_from: "{{ SYSTEM_EMAIL_FROM }}"
  smtp_require_tls: {{ SYSTEM_EMAIL_TLS | bool | lower }}
{% if SYSTEM_EMAIL_AUTH | bool %}
  smtp_auth_username: "{{ SYSTEM_EMAIL_USERNAME }}"
  smtp_auth_password: "{{ SYSTEM_EMAIL_PASSWORD }}"
{% endif %}
  resolve_timeout: 5m

route:
  group_by: ["alertname", "app"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: "default"
  routes:
    - matchers:
        - severity = "critical"
      repeat_interval: 1h

receivers:
  - name: "default"
    email_configs:
      - to: "{{ users.administrator.email }}"
        send_resolved: true
        headers:
          Subject: "[{{ '{{' }} .Status | toUpper {{ '}}' }}] {{ '{{' }} .CommonAnnotations.summary {{ '}}' }}"
{% if ALERTMANAGER_TELEGRAM_ENABLED | bool and ALERTMANAGER_TELEGRAM_BOT_TOKEN and ALERTMANAGER_TELEGRAM_CHAT_ID | int > 0 %}
    telegram_configs:
      - api_url: "https://api.telegram.org"
        bot_token: "{{ ALERTMANAGER_TELEGRAM_BOT_TOKEN }}"
        chat_id: {{ ALERTMANAGER_TELEGRAM_CHAT_ID | int }}
        send_resolved: true
        parse_mode: "HTML"
{% endif %}
{% if 'web-app-mattermost' in applications
      and lookup('config', 'web-app-mattermost', 'compose.services.prometheus.enabled', False)
      and ALERTMANAGER_MATTERMOST_WEBHOOK_URL %}
    # Mattermost incoming webhook (Slack-compatible format).
    # Gated on Mattermost being deployed with prometheus enabled so alertmanager
    # does not reference a non-existent endpoint when Mattermost is not in the stack.
    # Configure the incoming webhook URL in the inventory under
    # alerting.mattermost.webhook_url to enable channel notifications.
    slack_configs:
      - api_url: "{{ ALERTMANAGER_MATTERMOST_WEBHOOK_URL }}"
        send_resolved: true
        title: "[{{ '{{' }} .Status | toUpper {{ '}}' }}] {{ '{{' }} .CommonAnnotations.summary {{ '}}' }}"
        text: "{{ '{{' }} .CommonAnnotations.description {{ '}}' }}"
{% endif %}

inhibit_rules:
  - source_matchers:
      - severity = "critical"
    target_matchers:
      - severity = "warning"
    equal: ["alertname", "app"]
