  # Gitea — Go runtime + application metrics.
  # Requires GITEA__metrics__ENABLED = true in the Gitea environment config.
  # Enable via native_metrics.enabled: true in inventory.
  # Set native_metrics.token in inventory when Gitea token auth is configured.
  - job_name: "gitea"
    scheme: {{ lookup('tls', app_id, 'protocols.web') }}
    metrics_path: /metrics
    tls_config:
      insecure_skip_verify: {{ not (TLS_ENABLED | bool) }}
{% set token = lookup('config', app_id, 'native_metrics.token') %}
{% if token %}
    bearer_token: "{{ token }}"
{% endif %}
    static_configs:
      - targets: ["{{ lookup('domain', app_id) }}"]
        labels:
          app: "{{ app_id }}"
