{% set _svc_key = application_id | replace('web-app-', '') | replace('web-svc-', '') %}
server
{
  server_name {{ domain }};
  # Exposes the Ansible role ID as an nginx variable so Lua metrics handlers
  # can attach the 'app' label required by the monitoring ACs.
  set $app_id "{{ application_id }}";
  # Docker container name for this vhost — used by /healthz/live to query the
  # health_containers shared dict populated by the background Docker-socket timer.
  # Falls back to "" when the naming convention doesn't match (dict lookup is skipped).
  set $container_name "{{ lookup('config', application_id, 'compose.services.' + _svc_key + '.name', '') }}";
  {% include 'roles/sys-svc-proxy/templates/headers/buffers.conf.j2' %}

  {% if lookup('config',application_id, 'compose.services.oauth2.enabled', False) %}
    {% include 'roles/web-app-oauth2-proxy/templates/endpoint.conf.j2'%}
  {% endif %}

  {% include 'roles/sys-front-inj-all/templates/server.conf.j2'%}

  {% if webserver_extra_configuration is defined %}
    {# Additional Domain Specific Configuration #}
    {{ webserver_extra_configuration }}
  {% endif %}

  {% include 'roles/sys-front-tls/templates/nginx_ssl_header.j2' %}

  {% if lookup('config',application_id, 'compose.services.oauth2.enabled', False) %}
    {% set acl = lookup('config', application_id, 'compose.services.oauth2.acl', {}) %}

    {% if acl.blacklist is defined %}
      {# 1. Expose everything by default, then protect blacklisted paths #}
      {% set oauth2_proxy_enabled = false %}
      {% set location = "/" %}
      {% include 'roles/sys-svc-proxy/templates/location/html.conf.j2' %}

      {% for loc in acl.blacklist %}
        {% set oauth2_proxy_enabled = true %}
        {% set location = loc %}
        {% include 'roles/sys-svc-proxy/templates/location/html.conf.j2' %}
      {% endfor %}

    {% elif acl.whitelist is defined %}
      {# 2. Protect everything by default, then expose whitelisted paths #}
      {% set oauth2_proxy_enabled = true %}
      {% set location = "/" %}
      {% include 'roles/sys-svc-proxy/templates/location/html.conf.j2' %}

      {% for loc in acl.whitelist %}
        {% set oauth2_proxy_enabled = false %}
        {% set location = loc %}
        {% include 'roles/sys-svc-proxy/templates/location/html.conf.j2' %}
      {% endfor %}

    {% else %}
      {# 3. OAuth2 enabled but no (or empty) ACL — protect all #}
      {% set oauth2_proxy_enabled = true %}
      {% set location = "/" %}
      {% include 'roles/sys-svc-proxy/templates/location/html.conf.j2' %}
    {% endif %}

  {% else %}
    {# 4. OAuth2 completely disabled — expose all #}
    {% set oauth2_proxy_enabled = false %}
    {% set location = "/" %}
    {% include 'roles/sys-svc-proxy/templates/location/html.conf.j2' %}
  {% endif %}

  # Liveness probe — checks BOTH Docker container health AND HTTP reachability.
  # 1. Consults the health_containers shared dict (populated every 15 s by the
  #    background timer in nginx.conf) to detect containers that are "running"
  #    but whose Docker HEALTHCHECK has flipped to "unhealthy".
  # 2. Falls back to an HTTP sub-request so that apps without a Docker
  #    HEALTHCHECK are still probed correctly.
  # Returns 200 "live" only when both checks pass; 503 "down" otherwise.
  location = /healthz/live {
    access_log off;
    content_by_lua_block {
      local alive = true

      -- Step 1: Docker health check via shared dict.
      -- $container_name is set from the Jinja2 config lookup; empty string
      -- means no container name is known — skip and rely on HTTP probe only.
      local cname = ngx.var.container_name
      if cname and cname ~= "" then
        local status = ngx.shared.health_containers:get(cname)
        -- "down" = container is running but Docker HEALTHCHECK says unhealthy.
        -- nil    = timer hasn't run yet; do not penalise — fall through.
        if status == "down" then
          alive = false
        end
      end

      -- Step 2: TCP/HTTP reachability — catches crashed or exited containers.
      if alive then
        local res = ngx.location.capture("/_live_probe")
        if not res or res.status >= 500 then
          alive = false
        end
      end

      if alive then
        ngx.status = ngx.HTTP_OK
        ngx.header["Content-Type"] = "text/plain"
        ngx.print("live\n")
      else
        ngx.status = ngx.HTTP_SERVICE_UNAVAILABLE
        ngx.header["Content-Type"] = "text/plain"
        ngx.print("down\n")
      end
    }
  }

  # Internal backend probe used by /healthz/live and /metricz.
  # Not accessible to external clients.
  location = /_live_probe {
    internal;
    proxy_pass              http://127.0.0.1:{{ http_port }}/;
    proxy_set_header        Host $host;
    proxy_connect_timeout   2s;
    proxy_read_timeout      3s;
    proxy_intercept_errors  off;
  }

  # Readiness probe — proxies to the application backend.
  # Returns a non-5xx response when the app is up and accepting requests.
  # Returns 502/503 when the backend is down. Safe to expose publicly.
  location = /healthz/ready {
    access_log off;
    proxy_pass              http://127.0.0.1:{{ http_port }}/;
    proxy_set_header        Host $host;
    proxy_connect_timeout   3s;
    proxy_read_timeout      5s;
    proxy_intercept_errors  off;
  }

  {#
    Prometheus integration — two separate templates:

    1. location.conf.j2 (log_by_lua_block) — included in every app vhost that
       participates in monitoring (compose.services.prometheus.enabled = true).
       Records per-request metrics into the shared lua dict on every request.

    2. metricz.conf.j2 (location = /metricz) — included ONLY on the prometheus
       domain (compose.services.prometheus.name is set). This is the single scrape
       endpoint; exposing it on every app vhost would leak the full metrics payload
       and duplicate the /metricz surface needlessly.
  #}
  {% if lookup('config', application_id, 'compose.services.prometheus.enabled', False)
      or lookup('config', application_id, 'compose.services.prometheus.name', '') %}
  {# Per-request metrics collection — runs on every vhost in the monitoring stack. #}
  {% include 'roles/web-app-prometheus/templates/location.conf.j2' %}
  {% endif %}
  {% if lookup('config', application_id, 'compose.services.prometheus.name', '') %}
  {# Scrape endpoint — only on the prometheus domain itself. #}
  {% include 'roles/web-app-prometheus/templates/metricz.conf.j2' %}
  {% endif %}

}
