APP_BASE_URL={{ lookup('tls', application_id, 'url.base') }}
BASEROW_BASE_URL={{ lookup('tls', application_id, 'url.base') | dotenv_quote }}
OIDC_ISSUER_URL={{ OIDC.CLIENT.ISSUER_URL | dotenv_quote }}
ADMIN_USERNAME={{ lookup('users', 'administrator').username | dotenv_quote }}
ADMIN_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}
CANONICAL_DOMAIN={{ (lookup('applications', application_id).server.domains.canonical | first) | dotenv_quote }}

DASHBOARD_BASE_URL={{ lookup('tls', 'web-app-dashboard', 'url.base') | dotenv_quote }}
PROMETHEUS_BASE_URL={{ lookup('tls', 'web-app-prometheus', 'url.base') | dotenv_quote }}
MATOMO_BASE_URL={{ lookup('tls', 'web-app-matomo', 'url.base') | dotenv_quote }}

OIDC_SERVICE_ENABLED={{ lookup('config', application_id, 'services.oauth2.enabled') | string | lower }}
LDAP_SERVICE_ENABLED={{ BASEROW_LDAP_ENABLED | string | lower }}

NODE_TLS_REJECT_UNAUTHORIZED=0

# Service gate flags rendered for req 019 closure.
LOGOUT_SERVICE_ENABLED={{ lookup('config', application_id, 'services.logout.enabled') | string | lower }}
DASHBOARD_SERVICE_ENABLED={{ lookup('config', application_id, 'services.dashboard.enabled') | string | lower }}
MATOMO_SERVICE_ENABLED={{ lookup('config', application_id, 'services.matomo.enabled') | string | lower }}
# nocheck: playwright-service-gate — covered by sys-svc-mail integration tests, not the persona surface
EMAIL_SERVICE_ENABLED={{ lookup('config', application_id, 'services.email.enabled') | string | lower }}
OAUTH2_SERVICE_ENABLED={{ lookup('config', application_id, 'services.oauth2.enabled') | string | lower }}
PROMETHEUS_SERVICE_ENABLED={{ lookup('config', application_id, 'services.prometheus.enabled') | string | lower }}
