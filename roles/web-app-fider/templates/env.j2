# Fider configuration
# @see https://docs.fider.io/self-hosted/

BASE_URL={{ lookup('tls', application_id, 'url.base') }}
DATABASE_URL=postgresql://{{ lookup('database', application_id, 'username') }}:{{ lookup('database', application_id, 'password') }}@{{ lookup('database', application_id, 'host') }}:{{ lookup('database', application_id, 'port') }}/{{ lookup('database', application_id, 'name') }}?sslmode=disable
JWT_SECRET={{ (application_id ~ lookup('users', 'administrator').password) | hash('sha256') }}

{% set email = lookup('email', application_id) %}
# Email configuration. Fider's env loader hard-requires EMAIL_NOREPLY
# AND a complete EMAIL_SMTP_* set at startup (it `panic`s otherwise),
# regardless of whether the relay is reachable, so we render the full
# block unconditionally. The lookup('email', …) returns infinito.nexus
# defaults when services.email.enabled is false, which keeps the panic
# at bay on email-disabled stacks.
# @see https://docs.fider.io/self-hosted/
EMAIL_NOREPLY={{ email['from'] }}
EMAIL_SMTP_HOST={{ email.host }}
EMAIL_SMTP_PORT={{ email.port }}
EMAIL_SMTP_USERNAME={{ email.username }}
EMAIL_SMTP_PASSWORD={{ email.password | dotenv_quote }}
EMAIL_SMTP_ENABLE_STARTTLS={{ email.start_tls | lower }}
