# Fider configuration
# @see https://getfider.com/docs/hosting

BASE_URL={{ lookup('tls', application_id, 'url.base') }}
DATABASE_URL=postgresql://{{ lookup('database', application_id, 'username') }}:{{ lookup('database', application_id, 'password') }}@{{ lookup('database', application_id, 'host') }}:{{ lookup('database', application_id, 'port') }}/{{ lookup('database', application_id, 'name') }}?sslmode=disable
JWT_SECRET={{ (application_id ~ users.administrator.password) | hash('sha256') }}

{% if SYSTEM_EMAIL_ENABLED | bool %}
# Email configuration
# @see https://getfider.com/docs/hosting#email
EMAIL_NOREPLY={{ users['no-reply'].email }}
EMAIL_SMTP_HOST={{ SYSTEM_EMAIL_HOST }}
EMAIL_SMTP_PORT={{ SYSTEM_EMAIL_PORT }}
EMAIL_SMTP_USERNAME={{ users['no-reply'].email }}
EMAIL_SMTP_PASSWORD={{ users['no-reply'].tokens['web-app-mailu'] | dotenv_quote }}
EMAIL_SMTP_ENABLE_STARTTLS={{ SYSTEM_EMAIL_START_TLS | lower }}
{% endif %}
