# The central Playwright config consumes APP_BASE_URL as the
# `baseURL`, so it MUST be passed unquoted; otherwise `page.goto("/")`
# in the Joomla spec resolves to an invalid URL.
APP_BASE_URL={{ lookup('tls', 'web-app-dashboard', 'url.base') }}
OIDC_ISSUER_URL={{ OIDC.CLIENT.ISSUER_URL | dotenv_quote }}
JOOMLA_BASE_URL={{ lookup('tls', 'web-app-joomla', 'url.base') | dotenv_quote }}
ADMIN_USERNAME={{ lookup('users', 'administrator').username | dotenv_quote }}
ADMIN_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}
BIBER_USERNAME={{ lookup('users', 'biber').username | dotenv_quote }}
BIBER_PASSWORD={{ lookup('users', 'biber').password | dotenv_quote }}
CANONICAL_DOMAIN={{ (lookup('applications', application_id).server.domains.canonical | first) | dotenv_quote }}

# Service gate flags (requirement 006). Values MUST be literal "true"
# or "false". Joomla's OIDC integration is provided by the
# oauth2-proxy sidecar (no first-party Joomla 6 OIDC adapter), so the
# OIDC service flag is keyed off `services.oauth2.enabled`.
OIDC_SERVICE_ENABLED={{ lookup('config', application_id, 'services.oauth2.enabled') | string | lower }}
LDAP_SERVICE_ENABLED={{ lookup('config', application_id, 'services.ldap.enabled') | string | lower }}

# The Playwright container image has no custom ENTRYPOINT so the infinito CA cert
# is never injected. Without it npm fails when the Docker proxy intercepts
# registry.npmjs.org with a certificate signed by the infinito CA.
NODE_TLS_REJECT_UNAUTHORIZED=0
