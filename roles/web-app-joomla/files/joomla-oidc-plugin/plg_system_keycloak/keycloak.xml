<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
    <name>plg_system_keycloak</name>
    <author>Infinito Nexus</author>
    <creationDate>2026-04-30</creationDate>
    <copyright>(C) 2026 Infinito Nexus</copyright>
    <license>GPL-2.0-or-later</license>
    <version>1.0.0</version>
    <description>Native OIDC SSO against Keycloak for Joomla 6, with RBAC group mapping and an env-toggleable local-form fallback at /administrator?fallback=local.</description>
    <namespace path="src">Joomla\Plugin\System\Keycloak</namespace>
    <files>
        <folder plugin="keycloak">services</folder>
        <folder>src</folder>
        <folder>vendor</folder>
    </files>
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field name="dummy" type="hidden" default="1" />
            </fieldset>
        </fields>
    </config>
</extension>
