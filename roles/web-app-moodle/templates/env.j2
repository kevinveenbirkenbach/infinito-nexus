# Moodle runtime env. Single source of truth for config.php values —
# all variables below are required and consumed via getenv() in
# files/build/config.php. See docs/requirements/015-moodle-self-built.md.

MOODLE_WWWROOT={{ lookup('tls', application_id, 'url.base') | regex_replace('/$', '') }}
MOODLE_DATAROOT={{ MOODLE_DATA_DIR }}

# Database (mariadb shared)
MOODLE_DB_TYPE=mariadb
MOODLE_DB_HOST={{ lookup('database', application_id, 'host') }}
MOODLE_DB_PORT={{ lookup('database', application_id, 'port') }}
MOODLE_DB_NAME={{ lookup('database', application_id, 'name') }}
MOODLE_DB_USER={{ lookup('database', application_id, 'username') }}
MOODLE_DB_PASS={{ lookup('database', application_id, 'password') | dotenv_quote }}
MOODLE_DB_PREFIX=mdl_

# Reverse-proxy + SSL (front-proxy terminates TLS).
# REVERSEPROXY stays off because the project's front-proxy forwards
# the original Host header unchanged. Moodle's reverseproxyabused
# check fires when reverseproxy=true AND request host == wwwroot host
# (lib/setuplib.php), so enabling it would break web access.
# SSLPROXY remains on so Moodle trusts X-Forwarded-Proto: https from
# the OpenResty layer for its URL generation.
MOODLE_REVERSEPROXY=false
MOODLE_SSLPROXY=true

# Debug
MOODLE_DEBUG={{ MODE_DEBUG | bool }}

# Site identity
MOODLE_SITE_NAME={{ MOODLE_SITE_TITLE | dotenv_quote }}
MOODLE_ADMIN_EMAIL={{ lookup('config', application_id, 'users.administrator.email') }}
