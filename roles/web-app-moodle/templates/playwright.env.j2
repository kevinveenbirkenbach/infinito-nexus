APP_BASE_URL={{ lookup('tls', application_id, 'url.base') | dotenv_quote }}
DASHBOARD_BASE_URL={{ lookup('tls', 'web-app-dashboard', 'url.base') | dotenv_quote }}
OIDC_ISSUER_URL={{ OIDC.CLIENT.ISSUER_URL | dotenv_quote }}
KEYCLOAK_REALM_NAME={{ OIDC.CLIENT.REALM | dotenv_quote }}
MOODLE_OIDC_SCOPE_NAME={{ MOODLE_OIDC_CUSTOM_SCOPE | dotenv_quote }}
OIDC_CLIENT_ID={{ OIDC.CLIENT.ID | dotenv_quote }}
# Service-gating flags (req-006). The spec uses these to switch
# between variant 0 (SERVICE_OIDC=true: hybrid OIDC + LDAP sync) and
# variant 1 (SERVICE_OIDC=false: LDAP-only).
SERVICE_OIDC={{ MOODLE_OIDC_ENABLED | bool }}
SERVICE_LDAP={{ MOODLE_LDAP_ENABLED | bool }}
# LAM acts as an independent LDAP browser to verify that
# Keycloak-side profile edits propagate via the WRITABLE federation
# all the way down into the LDAP server. The verifier test is gated
# on SERVICE_LAM so it skips cleanly when web-app-lam is not enabled.
SERVICE_LAM={{ 'web-app-lam' in group_names }}
{% if 'web-app-lam' in group_names %}
LAM_BASE_URL={{ lookup('tls', 'web-app-lam', 'url.base') | dotenv_quote }}
LAM_PASSWORD={{ lookup('config', 'web-app-lam', 'credentials.administrator_password') | dotenv_quote }}
{% endif %}
ADMIN_USERNAME={{ lookup('users', 'administrator').username | dotenv_quote }}
ADMIN_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}
BIBER_USERNAME={{ lookup('users', 'biber').username | dotenv_quote }}
BIBER_PASSWORD={{ lookup('users', 'biber').password | dotenv_quote }}
CANONICAL_DOMAIN={{ (lookup('applications', application_id).server.domains.canonical | first) | dotenv_quote }}
