# Limit the bootstrap-time language-model download to a single pair so
# the deploy gate's readiness probe (~2.5 minutes) does not race the
# upstream argos-translate package mirror; with `LT_LOAD_ONLY` unset
# LibreTranslate downloads ~50 model packages on first start, which
# regularly trips the deploy timeout and surfaces upstream
# `IncompleteRead` errors when the mirror is congested.
LT_LOAD_ONLY=en,de
LT_DISABLE_FILES_TRANSLATION=true
