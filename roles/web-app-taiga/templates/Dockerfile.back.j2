FROM taigaio/taiga-back:{{ TAIGA_VERSION }}

{% if TAIGA_OIDC_ENABLED | bool %}
# The OIDC backend lives in the repository's back/ subdirectory, so git is
# required only for this build step.
RUN apt-get update && \
    apt-get install -y --no-install-recommends git && \
    pip install --no-cache-dir {{ TAIGA_PLUGIN_PIP_INSTALL_ARGS }} && \
    apt-get purge -y --auto-remove git && \
    rm -rf /var/lib/apt/lists/*
{% else %}
RUN pip install --no-cache-dir {{ TAIGA_PLUGIN_PIP_INSTALL_ARGS }}
{% endif %}
