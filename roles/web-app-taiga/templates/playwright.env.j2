APP_BASE_URL={{ lookup('tls', 'web-app-dashboard', 'url.base') }}
OIDC_ISSUER_URL={{ OIDC.CLIENT.ISSUER_URL | dotenv_quote }}
OIDC_BUTTON_TEXT={{ OIDC.BUTTON_TEXT | dotenv_quote }}
TAIGA_BASE_URL={{ lookup('tls', 'web-app-taiga', 'url.base') | dotenv_quote }}
TAIGA_OAUTH2_ENABLED={{ lookup('config', application_id, 'services.oauth2.enabled') | string | lower }}
TAIGA_OIDC_ENABLED={{ lookup('config', application_id, 'services.oidc.enabled') | string | lower }}
LOGIN_USERNAME={{ lookup('users', 'administrator').username | dotenv_quote }}
LOGIN_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}
ADMIN_USERNAME={{ lookup('users', 'administrator').username | dotenv_quote }}
ADMIN_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}
BIBER_USERNAME={{ lookup('users', 'biber').username | dotenv_quote }}
BIBER_PASSWORD={{ lookup('users', 'biber').password | dotenv_quote }}
CANONICAL_DOMAIN={{ lookup('domain', application_id) | dotenv_quote }}

# Taiga's post-login UI exposes no in-app logout control that the generic
# persona helpers recognize — the bespoke `dashboard to taiga login and
# logout` test drives Taiga's own logout flow. Block the generic flows
# via Rule 11 so they skip instead of failing on
# `no in-app logout control reachable`.
PERSONA_BIBER_BLOCKED=true
PERSONA_ADMINISTRATOR_BLOCKED=true

# Service gate flags rendered for closure.
DASHBOARD_BASE_URL={{ lookup('tls', 'web-app-dashboard', 'url.base') | dotenv_quote }}
{% if 'web-app-prometheus' in group_names %}
PROMETHEUS_BASE_URL={{ lookup('tls', 'web-app-prometheus', 'url.base') | dotenv_quote }}
{% endif %}
MATOMO_BASE_URL={{ lookup('tls', 'web-app-matomo', 'url.base') | dotenv_quote }}

DASHBOARD_SERVICE_ENABLED={{ lookup('config', application_id, 'services.dashboard.enabled') | string | lower }}
OIDC_SERVICE_ENABLED={{ lookup('config', application_id, 'services.oidc.enabled') | string | lower }}
# nocheck: playwright-service-gate — persona drives the OIDC path; LDAP federation is exercised in the LDAP-only matrix variant
LDAP_SERVICE_ENABLED={{ lookup('config', application_id, 'services.ldap.enabled') | string | lower }}
OAUTH2_SERVICE_ENABLED={{ lookup('config', application_id, 'services.oauth2.enabled') | string | lower }}
LOGOUT_SERVICE_ENABLED={{ lookup('config', application_id, 'services.logout.enabled') | string | lower }}
MATOMO_SERVICE_ENABLED={{ lookup('config', application_id, 'services.matomo.enabled') | string | lower }}
# nocheck: playwright-service-gate — covered by sys-svc-mail integration tests, not the persona surface
EMAIL_SERVICE_ENABLED={{ lookup('config', application_id, 'services.email.enabled') | string | lower }}
