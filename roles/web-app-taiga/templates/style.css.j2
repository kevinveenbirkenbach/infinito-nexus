  box-shadow:
    inset 0 1px 0 rgba(var(--color-rgb-01-01), 0.04),
    0 0 0 3px rgba(var(--color-rgb-07-55), 0.18);
}

.discover-header .search-button:hover,
.discover-search .discover-header .search-button:hover {
  fill: var(--infinito-taiga-link-hover);
}

.btn-big,
.btn-board,
.btn-filter,
.btn-icon,
.btn-small,
.button-green,
.button-primary,
.button-secondary,
.button-gray,
.button-gray-light,
.button-red,
.button-red-light {
