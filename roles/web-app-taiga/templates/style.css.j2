      rgba(var(--color-rgb-07-60), 0.95)
    );
  border: 1px solid var(--infinito-taiga-border);
}

.notification-message-error .icon-error,
.notification-message-error .icon-close,
.notification-light .close svg {
  fill: currentColor;
}

.notification-light {
  background:
    linear-gradient(
      {{ CSS_GRADIENT_ANGLE }}deg,
      rgba(var(--color-rgb-01-82), 0.96),
      rgba(var(--color-rgb-01-85), 0.98),
      rgba(var(--color-rgb-01-88), 0.92)
    );
}

.project-details .project-details-image .image,
.single-project .project-logo img,
.highlighted-project .project-logo img {
  border: 1px solid rgba(var(--color-rgb-01-01), 0.08);
  box-shadow: var(--infinito-taiga-shadow);
}

.profile-bar .profile-edition {
  background: rgba(var(--color-rgb-01-90), 0.72);
}

.profile-bar .flag path,
.profile-bar .location path,
.project-details .get-feedback-inner svg,
.project-details .looking-for-people-selector svg {
  fill: var(--infinito-taiga-text-muted);
}

.project-values-settings svg.icon-trash,
.profile-bar .flag:hover path,
.lightbox-sprint-add-edit .delete-sprint:hover,
.lightbox-sprint-add-edit .delete-sprint:hover .icon,
.project-details .use-default-image:hover,
.project-details .delete-project:hover {
  color: var(--infinito-taiga-danger);
  fill: var(--infinito-taiga-danger);
}

.kanban.swimlane .kanban-header {
  background: none;
  border: 0;
  box-shadow: none;
}

.kanban-filter tg-filter {
  border-color: var(--infinito-taiga-border-strong);
}

div.master .detail-header,
div.master .detail-title-wrapper,
div.master .sprint-table,
div.master .backlog-table-header,
div.master .backlog-table-body,
div.master .sprint-header,
div.master .burndown-graph-container {
  background: transparent;
  color: var(--infinito-taiga-text);
}

div.master .detail-header h2,
div.master .detail-title-wrapper h2,
div.master .sprint-header h2,
div.master .backlog-table-header h2 {
  color: var(--infinito-taiga-heading);
}

div.master p,
div.master span,
div.master label,
div.master .e2e-backlog-table,
div.master .detail-body-content,
div.master .sprint-summary-data,
div.master .summary-stats {
  color: var(--infinito-taiga-text);
}

div.master .user-story-data,
div.master .task-data,
div.master .issue-data,
div.master .card-data,
div.master .us-ref,
div.master .card-title {
  color: var(--infinito-taiga-text);
}

div.master .dropdown-user,
div.master .popover,
div.master .dropdown-menu {
  background:
    linear-gradient(
      {{ CSS_GRADIENT_ANGLE }}deg,
      rgba(var(--color-rgb-01-86), 0.98),
      rgba(var(--color-rgb-01-88), 0.97),
      rgba(var(--color-rgb-01-90), 0.96)
    );
  color: var(--infinito-taiga-text);
  border: 1px solid var(--infinito-taiga-border);
}

div.master .dropdown-user a,
div.master .popover a,
div.master .dropdown-menu a {
  color: var(--infinito-taiga-link);
}
