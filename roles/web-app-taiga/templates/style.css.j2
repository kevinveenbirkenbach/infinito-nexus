  stroke: var(--infinito-taiga-cool);
}

.dropdown-project-list .dropdown-project-list-ul {
  border-bottom-color: rgba(var(--color-rgb-01-45), 0.32);
}

.dropdown-project-list .dropdown-project-list-projects,
.dropdown-project-list .create-project-btn span,
.dropdown-project-list h2,
.dropdown-project-list .see-more-projects-btn {
  color: var(--infinito-taiga-heading);
}

.dropdown-project-list .dropdown-project-list-projects span {
  color: var(--infinito-taiga-link);
}

.dropdown-project-list .dropdown-project-list-link.active,
.dropdown-project-list .dropdown-project-list-link:hover {
  color: var(--infinito-taiga-link);
}

.dropdown-project-list:hover .dropdown-project-list-projects,
.dropdown-project-list.active .dropdown-project-list-projects {
  background: rgba(var(--color-rgb-01-45), 0.12);
}

.dropdown-project-list:hover .dropdown-project-list-projects span,
.dropdown-project-list.active .dropdown-project-list-projects span {
  color: var(--infinito-taiga-link);
}

.dropdown-project-list .create-project-btn svg {
  fill: var(--infinito-taiga-cool);
  stroke: var(--infinito-taiga-cool);
}

.dropdown-project-list .create-project-btn:hover span,
.dropdown-project-list .create-project-btn:hover svg {
  color: var(--infinito-taiga-heading);
  fill: var(--infinito-taiga-heading);
  stroke: var(--infinito-taiga-heading);
}

div.master input[type="date"],
div.master input[type="email"],
div.master input[type="number"],
div.master input[type="password"],
div.master input[type="search"],
div.master input[type="text"],
div.master input[type="url"],
div.master select,
div.master textarea,
.discover-header input[type="text"],
.lightbox-generic-bulk .bulk-status-selector {
  background:
    linear-gradient(
      {{ CSS_GRADIENT_ANGLE }}deg,
      rgba(var(--color-rgb-01-88), 0.96),
      rgba(var(--color-rgb-01-90), 0.94),
      rgba(var(--color-rgb-01-92), 0.92)
