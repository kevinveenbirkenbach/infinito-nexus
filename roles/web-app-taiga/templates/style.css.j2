:host,
:root {
  --infinito-taiga-canvas: var(--color-01-90);
  --infinito-taiga-surface: rgba(var(--color-rgb-01-86), 0.96);
  --infinito-taiga-surface-strong: rgba(var(--color-rgb-01-82), 0.98);
  --infinito-taiga-surface-soft: rgba(var(--color-rgb-01-79), 0.94);
  --infinito-taiga-surface-card: rgba(var(--color-rgb-01-84), 0.92);
  --infinito-taiga-surface-card-hover: rgba(var(--color-rgb-01-80), 0.94);
  --infinito-taiga-overlay: rgba(var(--color-rgb-01-93), 0.78);
  --infinito-taiga-border: rgba(var(--color-rgb-01-55), 0.30);
  --infinito-taiga-border-strong: rgba(var(--color-rgb-01-45), 0.48);
  --infinito-taiga-line: rgba(var(--color-rgb-01-25), 0.18);
  --infinito-taiga-shadow: 0 18px 40px rgba(var(--color-rgb-01-01), 0.08);
  --infinito-taiga-glow: 0 0 0 1px rgba(var(--color-rgb-01-45), 0.08), 0 18px 40px rgba(var(--color-rgb-01-01), 0.06);
  --infinito-taiga-heading: var(--color-01-18);
  --infinito-taiga-text: var(--color-01-22);
  --infinito-taiga-text-soft: var(--color-01-34);
  --infinito-taiga-text-muted: var(--color-01-46);
  --infinito-taiga-link: var(--color-01-35);
  --infinito-taiga-link-hover: var(--color-01-25);
  --infinito-taiga-warm: var(--color-01-42);
  --infinito-taiga-warm-hover: var(--color-01-32);
  --infinito-taiga-cool: var(--color-01-40);
  --infinito-taiga-cool-hover: var(--color-01-30);
  --infinito-taiga-success: var(--color-01-38);
  --infinito-taiga-success-hover: var(--color-01-28);
  --infinito-taiga-danger: var(--color-07-55);
  --infinito-taiga-danger-hover: var(--color-07-62);
  --infinito-taiga-badge: var(--color-01-40);
  --infinito-taiga-badge-soft: rgba(var(--color-rgb-01-40), 0.16);

  --color-01-solid-primary: var(--infinito-taiga-cool);
  --color-01-link-primary: var(--infinito-taiga-link);
  --color-01-link-tertiary: var(--infinito-taiga-link-hover);
  --color-01-gray100: var(--color-01-93);
  --color-01-gray200: var(--color-01-87);
  --color-01-gray300: var(--color-01-78);
  --color-01-gray400: var(--color-01-62);
  --color-01-black600: var(--color-01-38);
  --color-01-black700: var(--color-01-30);
  --color-01-black800: var(--color-01-18);
  --color-01-black900: var(--color-01-10);
  --color-01-black: var(--color-01-03);
  --color-01-white: var(--color-01-99);
}

div.master,
.blocked-project-detail,
.transfer-project {
  background:
    radial-gradient(circle at top right, rgba(var(--color-rgb-01-72), 0.08), transparent 30%),
    linear-gradient(
      {{ CSS_GRADIENT_ANGLE }}deg,
      rgba(var(--color-rgb-01-90), 0.98),
      rgba(var(--color-rgb-01-88), 0.97),
      rgba(var(--color-rgb-01-92), 0.94)
    );
  color: var(--infinito-taiga-text);
}

.wrapper,
.main,
.profile .main,
section.main.kanban {
  background-color: transparent;
  color: var(--infinito-taiga-text);
}

div.master h1,
div.master h2,
div.master h3,
div.master h4,
div.master h5,
div.master h6 {
  color: var(--infinito-taiga-heading);
}

div.master h1 a,
div.master h2 a,
div.master h3 a,
div.master h4 a,
div.master h5 a,
div.master h6 a,
div.master a,
div.master a:visited {
  color: var(--infinito-taiga-link);
}

div.master a:hover,
div.master a:visited:hover,
.btn-link:hover,
.btn-link[variant="icon"]:hover {
  color: var(--infinito-taiga-link-hover);
}

div.master hr,
.profile-bar .profile-stats,
.profile-timeline,
.profile-timeline .activity-item,
.project-details .get-feedback,
.project-details .looking-for-people,
.transfer-project-detail,
.project-list-wrapper .dropdown-project-list-ul {
  border-color: var(--infinito-taiga-line);
}

.menu-secondary,
.menu-secondary li,
.menu-secondary .settings-nav,
.menu-tertiary {
  background:
    linear-gradient(
      {{ CSS_GRADIENT_ANGLE }}deg,
      rgba(var(--color-rgb-01-84), 0.96),
      rgba(var(--color-rgb-01-86), 0.97),
      rgba(var(--color-rgb-01-88), 0.98)
    );
  color: var(--infinito-taiga-text-soft);
}

.menu-secondary,
.menu-tertiary {
  border-right: 1px solid var(--infinito-taiga-border);
  box-shadow: inset -1px 0 0 rgba(var(--color-rgb-01-01), 0.06);
}

.menu-secondary li a,
.menu-tertiary ul li a {
  color: var(--infinito-taiga-text-soft);
}

.menu-secondary li:hover,
.menu-secondary li:hover a,
.menu-tertiary ul li:hover,
.menu-tertiary ul li:hover a {
  background: rgba(var(--color-rgb-01-45), 0.12);
  color: var(--infinito-taiga-heading);
}

.menu-secondary li .active,
.menu-secondary li .active:hover {
  background: rgba(var(--color-rgb-01-82), 0.98);
  box-shadow: inset 3px 0 0 var(--infinito-taiga-cool);
}

.menu-secondary li .active a,
.menu-secondary li .active:hover a,
.menu-tertiary ul li.active a,
.menu-tertiary ul li.active a:hover {
  background: transparent;
  color: var(--infinito-taiga-link);
}

.menu-tertiary ul li.active {
  background: rgba(var(--color-rgb-01-45), 0.14);
}

.project-list-wrapper .project-list-title,
.project-values-title,
.home-wrapper .title-bar,
div.kanban-header,
.kanban-table-header .task-colum-name {
  background:
    linear-gradient(
      {{ CSS_GRADIENT_ANGLE }}deg,
      rgba(var(--color-rgb-01-75), 0.95),
      rgba(var(--color-rgb-01-78), 0.98),
      rgba(var(--color-rgb-01-82), 0.97)
    );
  border: 1px solid var(--infinito-taiga-border);
  box-shadow: var(--infinito-taiga-glow);
  color: var(--infinito-taiga-heading);
}

.project-list-wrapper .project-list-title h1,
.project-values-title h2,
.discover-results-header h2,
.discover-results-header .title,
section.kanban h1,
section.kanban h2 {
  color: var(--infinito-taiga-heading);
}

.discover-header form,
.dropdown-project-list .navbar-dropdown,
.lightbox section,
.lightbox form,
.home-project,
.project-list-wrapper .list-itemtype-project,
.project-list-wrapper .gu-mirror,
.single-project,
.highlighted-project,
.featured-project,
.profile-bar,
.project-details .project-details-form-data,
.project-details .project-details-image,
.profile-timeline,
.notification-light {
