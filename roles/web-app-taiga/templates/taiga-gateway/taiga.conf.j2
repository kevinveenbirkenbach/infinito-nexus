server {
    listen 80 default_server;

    {{ NETWORK_DOCKER_DNS_NGINX_DIRECTIVE }}

    set $upstream_taiga_front     http://taiga-front;
    set $upstream_taiga_back      http://taiga-back:8000;
    set $upstream_taiga_protected http://taiga-protected:8003;
    set $upstream_taiga_events    http://taiga-events:8888;

    client_max_body_size 100M;
    charset utf-8;

    # Frontend
    location / {
        proxy_pass $upstream_taiga_front;
        proxy_pass_header Server;
        proxy_set_header Host $http_host;
        proxy_redirect off;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Scheme $scheme;
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;
    }

    # API
    location /api/ {
        proxy_pass $upstream_taiga_back;
        proxy_pass_header Server;
        proxy_set_header Host $http_host;
        proxy_redirect off;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Scheme $scheme;
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;
    }

    # OIDC auth endpoints
    location = /oidc {
        return 301 /oidc/;
    }

    location /oidc/ {
        proxy_pass $upstream_taiga_back;
        proxy_pass_header Server;
        proxy_set_header Host $http_host;
        proxy_redirect off;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Scheme $scheme;
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # Admin
    location /admin/ {
        proxy_pass $upstream_taiga_back;
        proxy_pass_header Server;
        proxy_set_header Host $http_host;
        proxy_redirect off;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Scheme $scheme;
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;
    }

    # Static
    location /static/ {
        alias /taiga/static/;
    }

    # Media
    location /_protected/ {
        internal;
        alias /taiga/media/;
        add_header Content-disposition "attachment";
    }

    # Unprotected section
    location /media/exports/ {
        alias /taiga/media/exports/;
        add_header Content-disposition "attachment";
    }

    location /media/ {
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Scheme $scheme;
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        rewrite ^/media/(.*)$ /$1 break;
        proxy_pass $upstream_taiga_protected;
        proxy_redirect off;
    }

    # Events
    location /events {
        proxy_pass $upstream_taiga_events;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_connect_timeout 7d;
        proxy_send_timeout 7d;
        proxy_read_timeout 7d;
    }
}
