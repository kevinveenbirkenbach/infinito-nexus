# OpenTalk controller env (settings overridable via OPENTALK_CTRL_<SECTION>__<KEY>).
# The bulk of configuration lives in the mounted controller.toml; values here
# are environment-only overrides that are convenient to change without
# re-rendering the TOML (e.g. log verbosity).

RUST_LOG={{ 'debug' if MODE_DEBUG | bool else 'info' }}
OPENTALK_CTRL_LOG__LEVEL={{ 'debug' if MODE_DEBUG | bool else 'info' }}
